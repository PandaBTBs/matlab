function [x1, x2] = root2(a, b, c)
% ROOT2 вычисляет действительные корни квадратного уравнения a*x^2 + b*x + c = 0
% [x1, x2] = root2(a, b, c)

% Проверка количества входных аргументов
if nargin ~= 3
    error('Ошибка: необходимо ввести ровно 3 входных аргумента (a, b, c)!');
end

% Проверка количества выходных аргументов
if nargout ~= 2
    error('Ошибка: необходимо указать 2 выходных аргумента [x1, x2]!');
end

% Проверка, что аргументы являются числами (скалярами)
if ~isscalar(a) || ~isscalar(b) || ~isscalar(c)
    error('Ошибка: a, b, c должны быть числами (скалярами), а не массивами!');
end

% Проверка, что аргументы действительные
if ~isreal(a) || ~isreal(b) || ~isreal(c)
    error('Ошибка: a, b, c должны быть действительными числами!');
end

% Проверка, что a не равно нулю (иначе уравнение не квадратное)
if a == 0
    error('Ошибка: коэффициент a не может быть равен нулю (это не квадратное уравнение)!');
end

% Вычисление дискриминанта
D = b^2 - 4*a*c;

% Проверка вещественности корней
if D < 0
    error('Ошибка: дискриминант отрицателен, действительных корней нет!');
end

% Вычисление корней
x1 = (-b - sqrt(D)) / (2*a);
x2 = (-b + sqrt(D)) / (2*a);

end

[x1, x2] = root2(1, -3, 2)   % корни 1 и 2
[x1, x2] = root2(1, 0, 1)     % ошибка – нет действительных корней







function ifdem(a)
% IFDEM демонстрирует работу условного оператора if-elseif-else

if a == 0
    disp('a равно нулю');
elseif a == 1
    disp('a равно единице');
elseif a == 2
    disp('a равно двум');
elseif a >= 3
    disp('a больше или равно трем');
else
    disp('a меньше трех, но не ноль, не единица и не двойка');
end

end


ifdem(1)
ifdem(1.2)
ifdem(2)
ifdem(3)
ifdem(-1)









function y = pwfun(x)
% PWFUN вычисляет кусочно-заданную функцию для скалярного x
%   sin(x) - 1,   если x < -pi
%   x / pi,       если -pi <= x < pi
%   -cos(x),      если x >= pi

if x < -pi
    y = sin(x) - 1;
elseif x < pi
    y = x / pi;
else
    y = -cos(x);
end

end

pwfun(-4)   % sin(-4)-1
pwfun(0)    % 0/pi = 0
pwfun(4)    % -cos(4)


fplot(@pwfun, [-3*pi, 3*pi])
grid on
title('Кусочно-заданная функция pwfun(x)')








function y = pwfun1(x)
% PWFUN1 вычисляет кусочно-заданную функцию для числа или вектора
%   sin(x) - 1,   если x < -pi
%   x / pi,       если -pi <= x < pi
%   -cos(x),      если x >= pi

% Проверка входных аргументов
if nargin ~= 1
    error('Ошибка: необходимо ровно 1 входной аргумент!');
end

% Проверка, что входной аргумент – вектор (строка или столбец) или скаляр
if ~isvector(x) && ~isscalar(x)
    error('Ошибка: входной аргумент должен быть числом или вектором!');
end

% Инициализация выходного массива
y = zeros(size(x));

% Перебор элементов
for i = 1:length(x)
    if x(i) < -pi
        y(i) = sin(x(i)) - 1;
    elseif x(i) < pi
        y(i) = x(i) / pi;
    else
        y(i) = -cos(x(i));
    end
end

end



x_vec = [-4, 0, 4];
y_vec = pwfun1(x_vec)

% Построение графика
x = linspace(-3*pi, 3*pi, 100);
y = pwfun1(x);
plot(x, y)
grid on
title('pwfun1 – работает с вектором')













function y = pwfun2(X)
% PWFUN2 вычисляет кусочно-заданную функцию для числа, вектора или матрицы
%   sin(x) - 1,   если x < -pi
%   x / pi,       если -pi <= x < pi
%   -cos(x),      если x >= pi

% Проверка входных аргументов
if nargin ~= 1
    error('Ошибка: необходимо ровно 1 входной аргумент!');
end

% Проверка, что входной аргумент – число, вектор или матрица
if ~isnumeric(X)
    error('Ошибка: входной аргумент должен быть числовым массивом!');
end

% Инициализация выходного массива
y = zeros(size(X));

% Вложенные циклы для перебора строк и столбцов
for i = 1:size(X, 1)      % строки
    for j = 1:size(X, 2)  % столбцы
        if X(i, j) < -pi
            y(i, j) = sin(X(i, j)) - 1;
        elseif X(i, j) < pi
            y(i, j) = X(i, j) / pi;
        else
            y(i, j) = -cos(X(i, j));
        end
    end
end

end


X = [-4, 0, 4; -5, 1, 5];
Y = pwfun2(X)

% Для скаляра тоже работает
pwfun2(2)
